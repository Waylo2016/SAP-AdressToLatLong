# Google Geocoding API key
GOOGLE_GEOCODING_API_KEY=your_google_api_key_here

# Run mode: SQL or SAP
# SQL: Uses direct database access
# SAP: Uses SAP DI API
RUN_MODE=SQL

# SAP DI API Requirements
SAP_DATABASE_URL=
SAP_DATABASE_USERNAME=
SAP_DATABASE_PASSWORD=

# DI API SQL version (e.g., 2016, 2017, 2019, 2022, or HANA)
SAP_DI_API_SQL_VERSION=

# Direct SQL Database Requirements
SQL_DATABASE_URL=
SQL_DATABASE_USERNAME=
SQL_DATABASE_PASSWORD=
